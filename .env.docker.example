# Copy to .env.docker and set only the credentials required by this deployment.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v4-flash
DASHSCOPE_API_KEY=

# Keep the safe Schema cache as the default. Set chroma only after installing
# requirements-chroma.txt into a custom image and validating that environment.
SCHEMA_VECTOR_BACKEND=dashscope_memory
DATA_AGENT_AUTH_MODE=development
API_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
