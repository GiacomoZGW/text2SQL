# Copy to .env.docker and set only the credentials required by this deployment.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_MAX_TOKENS=4096
DASHSCOPE_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_MAX_RETRIES=3

# Proxy values are resolved by Docker Compose from the project-level .env.
# Never use 127.0.0.1 for a host proxy inside a container; use
# http://host.docker.internal:<port> instead.
# CONTAINER_HTTP_PROXY=http://host.docker.internal:7897
# CONTAINER_HTTPS_PROXY=http://host.docker.internal:7897
# CONTAINER_NO_PROXY=localhost,127.0.0.1,redis,postgres,api,worker

# Keep the safe Schema cache as the default. Set chroma only after installing
# requirements-chroma.txt into a custom image and validating that environment.
SCHEMA_VECTOR_BACKEND=dashscope_memory
DATA_AGENT_AUTH_MODE=development
API_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
TASK_EXECUTION_MODE=redis_streams
REDIS_SOCKET_TIMEOUT_SECONDS=10
DURABLE_TASK_WORKER_RETRY_SECONDS=1

# DATA_AGENT_AUTH_MODE=oidc
# OIDC_ISSUER=https://login.example.com/realms/data
# OIDC_AUDIENCE=data-agent-api
# OIDC_JWKS_URL=https://login.example.com/realms/data/protocol/openid-connect/certs
# AUTH_RATE_LIMIT_ENABLED=true
# AUTH_RATE_LIMIT_WINDOW_SECONDS=60
# AUTH_RATE_LIMIT_REQUESTS=60
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# OTEL_SERVICE_NAME=data-agent

# PostgreSQL is the shared source of truth for memory, audit and observability
# state in Docker deployments. Do not use these development defaults in a real
# environment; place the real password in .env.docker or a secret manager.
POSTGRES_STATE_DB=data_agent
POSTGRES_STATE_USER=data_agent
POSTGRES_STATE_PASSWORD=data_agent_dev
POSTGRES_STATE_PORT=5432
