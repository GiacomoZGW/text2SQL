# Local runtime configuration. Copy to .env and set credentials locally.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=

LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_MAX_TOKENS=4096

EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_MAX_RETRIES=3

# Docker containers connect directly by default. If a host proxy is required,
# use host.docker.internal instead of 127.0.0.1, for example:
# CONTAINER_HTTP_PROXY=http://host.docker.internal:7897
# CONTAINER_HTTPS_PROXY=http://host.docker.internal:7897
# CONTAINER_NO_PROXY=localhost,127.0.0.1,redis,postgres,api,worker

# Optional shared runtime state for local PostgreSQL.
# RUNTIME_DATABASE_URL=postgresql://data_agent:data_agent_dev@127.0.0.1:5432/data_agent

# Authentication: use development only on a local machine. OIDC validates a
# Bearer JWT against a rotating JWKS; OIDC_JWT_SECRET exists only for local test IdPs.
# DATA_AGENT_AUTH_MODE=oidc
# OIDC_ISSUER=https://login.example.com/realms/data
# OIDC_AUDIENCE=data-agent-api
# OIDC_JWKS_URL=https://login.example.com/realms/data/protocol/openid-connect/certs
# OIDC_USER_CLAIM=sub
# OIDC_TENANT_CLAIM=tenant_id
# OIDC_ROLE_CLAIM=roles
# AUTH_RATE_LIMIT_ENABLED=true
# AUTH_RATE_LIMIT_WINDOW_SECONDS=60
# AUTH_RATE_LIMIT_REQUESTS=60

# Optional OpenTelemetry OTLP/HTTP exporter. Request, Agent, LLM and SQL spans
# carry the API request ID as a correlation attribute.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# OTEL_SERVICE_NAME=data-agent
